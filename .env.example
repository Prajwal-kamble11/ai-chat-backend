# ---------------------------------------------
# AI Chat Backend Environment Variables Example
# ---------------------------------------------

# PostgreSQL Database Connection URL
# Example: postgresql+asyncpg://user:password@localhost:5432/aichat_db
DATABASE_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/dbname

# Groq API Key (Used to interface with LLaMA 3.1)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Hugging Face (Used for Knowledge Base Embeddings)
HUGGINGFACE_TOKEN=your_huggingface_token
HF_API_URL=https://router.huggingface.co/hf-inference/models/sentence-transformers/all-MiniLM-L6-v2/pipeline/feature-extraction

# Redis URL (Used for Rate-limiting and Arq background workers)
REDIS_URL=redis://localhost:6379

# JWT Authentication
SECRET_KEY=your_random_secret_key_here
ALGORITHM=HS256

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
