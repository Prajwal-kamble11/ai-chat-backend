# ---------------------------------------------
# AI Chat Backend Environment Variables Example
# ---------------------------------------------

# PostgreSQL Database Connection URL (must use asyncpg for asynchronous SQLAlchemy)
# Example: postgresql+asyncpg://user:password@localhost:5432/aichat_db
DATABASE_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/dbname

# Groq API Key (Used to interface with LLaMA 3.1)
# You can generate this from the Groq Developer Console
GROQ_API_KEY=gsk_your_groq_api_key_here_dummy_value

# Redis URL (Used for API Gateway rate-limiting, and Arq background workers)
# Defaults to localhost:6379 if not provided.
REDIS_URL=redis://localhost:6379

# Clerk Authentication
# Add your clerk secret key for official SDK validation
CLERK_SECRET_KEY=sk_test_yw9DTENlC7fiPAr5oJrOESuWXdvQ2tSdMM9YStvUer
# Add your JWKS url to safely verify token signatures locally (e.g. https://<YOUR_CLERK_DOMAIN>/.well-known/jwks.json)
CLERK_JWKS_URL=https://...

# Razorpay Payment Gateway
# Get these from dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
